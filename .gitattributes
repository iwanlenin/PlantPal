# Default: normalize to LF on commit, checkout as-is on Windows
* text=auto

# C# and MAUI files — LF
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Shell scripts — must stay LF for bash
*.sh text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.apk binary
*.aab binary
*.ipa binary
