<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PlantPal"
             xmlns:conv="clr-namespace:PlantPal.Converters"
             x:Class="PlantPal.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters -->
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:IntToBoolConverter x:Key="IntToBoolConverter" />
            <conv:PluralConverter x:Key="PluralConverter" />
            <conv:StringToBoolConverter x:Key="StringToBoolConverter" />
            <conv:InvertedStringToBoolConverter x:Key="InvertedStringToBoolConverter" />
            <conv:ObjectToBoolConverter x:Key="ObjectToBoolConverter" />
            <conv:EditModeTitleConverter x:Key="EditModeTitleConverter" />
            <conv:RoleToUserBoolConverter x:Key="RoleToUserBoolConverter" />
            <conv:RoleToAssistantBoolConverter x:Key="RoleToAssistantBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
