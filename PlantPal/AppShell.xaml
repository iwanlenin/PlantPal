<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PlantPal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:PlantPal.Pages"
    Title="PlantPal"
    Shell.BackgroundColor="{StaticResource Background}"
    Shell.ForegroundColor="{StaticResource TextPrimary}"
    Shell.TabBarBackgroundColor="{StaticResource Background}"
    Shell.TabBarForegroundColor="{StaticResource Primary}"
    Shell.TabBarUnselectedColor="{StaticResource TextSecondary}"
    Shell.UnselectedColor="{StaticResource TextSecondary}">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="&#x1F331;"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="Dashboard" />

        <ShellContent
            Title="All Plants"
            Icon="&#x1F4CB;"
            ContentTemplate="{DataTemplate pages:PlantListPage}"
            Route="PlantList" />

        <ShellContent
            Title="Settings"
            Icon="&#x2699;"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="Settings" />

        <ShellContent
            Title="Account"
            Icon="&#x1F464;"
            ContentTemplate="{DataTemplate pages:AccountPage}"
            Route="Account" />
    </TabBar>

</Shell>
