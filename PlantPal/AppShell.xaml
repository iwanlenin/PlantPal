<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PlantPal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:PlantPal.Pages"
    Title="PlantPal"
    Shell.BackgroundColor="{StaticResource Background}"
    Shell.ForegroundColor="{StaticResource TextPrimary}">

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate pages:DashboardPage}"
        Route="Dashboard" />

</Shell>
