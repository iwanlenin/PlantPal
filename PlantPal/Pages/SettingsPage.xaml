<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:PlantPal.Core.ViewModels;assembly=PlantPal.Core"
    x:Class="PlantPal.Pages.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    Title="Settings"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Permissions section -->
            <Label
                Text="Permissions"
                FontSize="13"
                FontAttributes="Bold"
                TextColor="{StaticResource TextSecondary}"
                CharacterSpacing="1.2" />

            <Border
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                StrokeThickness="0"
                Padding="20"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="0">

                    <!-- Notifications row -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4" Padding="0,0,0,16">
                        <Label
                            Grid.Row="0" Grid.Column="0"
                            Text="Notifications"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />
                        <Label
                            Grid.Row="1" Grid.Column="0"
                            Text="{Binding NotificationStatus}"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />
                        <Button
                            Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                            Text="Open Settings"
                            FontSize="13"
                            TextColor="{StaticResource Primary}"
                            BackgroundColor="Transparent"
                            Padding="0"
                            VerticalOptions="Center"
                            Clicked="OnOpenSettingsTapped" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView
                        HeightRequest="1"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Margin="0,0,0,16" />

                    <!-- Photo Access row -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label
                            Grid.Row="0" Grid.Column="0"
                            Text="Photo Access"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />
                        <Label
                            Grid.Row="1" Grid.Column="0"
                            Text="{Binding PhotoStatus}"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />
                        <Button
                            Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                            Text="Open Settings"
                            FontSize="13"
                            TextColor="{StaticResource Primary}"
                            BackgroundColor="Transparent"
                            Padding="0"
                            VerticalOptions="Center"
                            Clicked="OnOpenSettingsTapped" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Preferences section -->
            <Label
                Text="Preferences"
                FontSize="13"
                FontAttributes="Bold"
                TextColor="{StaticResource TextSecondary}"
                CharacterSpacing="1.2" />

            <Border
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                StrokeThickness="0"
                Padding="20"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="0">

                    <!-- Daily reminder row -->
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" Padding="0,0,0,16">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label
                                Text="Daily reminder"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextPrimary}" />
                            <Label
                                Text="Notification time for watering reminders"
                                FontSize="13"
                                TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <TimePicker
                            x:Name="ReminderTimePicker"
                            Grid.Column="1"
                            Time="{Binding ReminderTime}"
                            TextColor="{StaticResource TextPrimary}"
                            VerticalOptions="Center"
                            PropertyChanged="OnReminderTimeChanged" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView
                        HeightRequest="1"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Margin="0,0,0,16" />

                    <!-- Weather-aware watering row -->
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label
                                Text="Weather-aware watering"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextPrimary}" />
                            <Label
                                Text="Postpone outdoor reminders after rainfall"
                                FontSize="13"
                                TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding IsWeatherAwareEnabled}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center"
                            Toggled="OnWeatherToggled" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
