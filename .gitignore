## .NET / MAUI gitignore

# Build outputs
bin/
obj/
*.user
*.suo
.vs/

# NuGet
*.nupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Rider
.idea/

# VS Code
.vscode/

# OS
.DS_Store
Thumbs.db

# Android
*.apk
*.aab

# iOS
*.ipa
*.dSYM/

# Test results
TestResults/
coverage/

# Secrets
*.env
*.env.local
appsettings.Development.json

# MAUI hot reload
**/.hotreload/
